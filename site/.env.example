# ─── Café Laren — environment variables ─────────────────────────────────
# Copy this file to .env.local and fill in real values. Never commit
# .env.local — it's gitignored. In production set these in your host
# (Vercel project → Settings → Environment Variables).

# ─── Database — Supabase Postgres ────────────────────────────────────────
# Get from https://supabase.com/dashboard/project/<ref>/settings/database
#
#   • DATABASE_URL — runtime queries. Use the **Connection pooler** URL
#     (Transaction mode, port 6543) for serverless / Vercel deploys.
#     For local dev the direct URL (port 5432) is fine too.
#   • DIRECT_URL — used by drizzle-kit for migrations. Migrations don't
#     work over the pooler, so this MUST be the direct connection (5432).
DATABASE_URL="postgresql://postgres:YOUR-PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:YOUR-PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres"

# ─── Admin login (/admin) ────────────────────────────────────────────────
# Owner enters this password to access the dashboard. Change before going live.
ADMIN_PASSWORD="change-me-to-a-strong-password"

# ─── Cookie session signing ──────────────────────────────────────────────
# 32+ random characters. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET="change-me-to-a-random-32-char-string-or-longer"

# ─── Public site URL ─────────────────────────────────────────────────────
# Used for SEO metadata + LocalBusiness JSON-LD.
# Local: http://localhost:3000
# Production: your custom domain (e.g. https://cafe-laren.de)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
